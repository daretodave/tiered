# tiered.tv — environment shape. Copy to .env and fill in real values.
# Never commit .env (it's in .gitignore).

# GitHub PAT — used by the loop for push, gh API calls, /triage
# Fine-grained, scoped to the tiered repo only:
# Contents: Read & Write, Issues: Read & Write, Metadata: Read
# Same value is used in Actions as ACTIONS_PAT
GH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxx

# Claude Code OAuth token — for the cloud loop on GitHub Actions
# Generated via: claude setup-token (run in local Claude Code session)
# Bills cloud-loop runs against your Pro/Max subscription ($0 marginal on public repo)
# Alternative: ANTHROPIC_API_KEY (pay-per-token, ~$3-20/day) — not recommended for personal projects
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxxxx

# Vercel — project, team, and deploy-gate auth
# Token: https://vercel.com/account/tokens
# Team ID: vercel.com/teams/<team>/settings  → look for ID
VERCEL_TOKEN=vcp_xxxxxxxxxxxxxxxxxxxxxx
VERCEL_PROJECT=tiered
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxx

# Supabase — Postgres + auth helpers + RLS for votes/comments/sessions
# Project: https://supabase.com/dashboard/projects
# Note: newer projects use "publishable key" (NEXT_PUBLIC_*) and "secret/service role key"
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
SUPABASE_PROJECT_ID=<project>
SUPABASE_REGION=us-west-2
SUPABASE_DB_PASSWORD=
# Server-only; never expose to the browser. From Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Auth0 — magic link + anonymous-guest sessions
# Tenant: https://manage.auth0.com
AUTH0_DOMAIN=<tenant>.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://api.tiered.app

# OpenAI — runtime AI for comment moderation pre-filter
# Editorial content (blurbs, canon rationales) is agent-generated during /iterate
# using the Claude Code session's own auth — no API key needed for that.
# This key is server-only; used by /api/comment.
# Console: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx

# E2E test user — for hermetic auth. Create in Auth0 Username-Password-Authentication connection.
# Used by scripts/mint-e2e-cookie.mjs (password-realm grant) to mint a session cookie for
# both Playwright tests AND the /critique reader sub-agent.
# Requires "Resource Owner Password" grant enabled on the Auth0 application.
E2E_USER_EMAIL=e2e@<your-domain>
E2E_USER_PASSWORD=

# Auto-managed by scripts/mint-e2e-cookie.mjs. Format: __session=<encrypted-jwt>
CRITIQUE_SESSION_COOKIE=
