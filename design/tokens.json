{
  "$schema": "tiered-tv.tokens.v1",
  "mode": {
    "dark": {
      "paper": {
        "0": "#0E0B08",
        "1": "#15110C",
        "2": "#1E1812",
        "3": "#2A2218"
      },
      "line": {
        "soft":  "#241D14",
        "base":  "#3A2F22",
        "loud":  "#5A4A35"
      },
      "ink": {
        "3": "#6E6353",
        "2": "#9D9485",
        "1": "#D8CFBE",
        "0": "#F2EADB"
      },
      "primary": {
        "base": "#E8B65A",
        "soft": "#C9963F",
        "loud": "#FFD27A"
      }
    },
    "light": {
      "paper": {
        "0": "#F5EFE3",
        "1": "#EEE7D7",
        "2": "#E5DDC9",
        "3": "#DBD2BC"
      },
      "line": {
        "soft": "#D9CFB6",
        "base": "#C8BC9F",
        "loud": "#A8997A"
      },
      "ink": {
        "3": "#8A7E64",
        "2": "#5D533F",
        "1": "#3A3225",
        "0": "#1A1610"
      },
      "primary": {
        "base": "#8B5A1F",
        "soft": "#A8742E",
        "loud": "#6B4416"
      }
    }
  },
  "sentiment": {
    "warm-up":   { "dark": "#E0843A", "light": "#B2611E", "use": "Rank rising; +N pill; vote-up flash" },
    "warm-down": { "dark": "#5A8FA6", "light": "#356A82", "use": "Rank falling; -N pill; vote-down flash" },
    "neutral":   { "dark": "#8C8275", "light": "#6E6553", "use": "No change; zero-delta state" },
    "hold":      { "dark": "#7A8F5C", "light": "#566B3D", "use": "Locked / held position; finale-protected" },
    "verdict":   { "dark": "#B57FB8", "light": "#7E4A82", "use": "Editor's Canon delta (rare, editorial)" },
    "consensus": { "dark": "#D5A93D", "light": "#8B6A1A", "use": "Community rank reaches stable consensus" }
  },
  "type": {
    "family": {
      "serif": "'Source Serif 4', 'Source Serif Pro', Georgia, serif",
      "sans":  "'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif",
      "mono":  "'JetBrains Mono', 'IBM Plex Mono', ui-monospace, monospace"
    },
    "weight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "scale": {
      "xs":  { "size": "12px", "lh": "16px", "use": "Caption, meta, mono ranks" },
      "sm":  { "size": "14px", "lh": "20px", "use": "Secondary UI, helper" },
      "base":{ "size": "16px", "lh": "24px", "use": "Body" },
      "md":  { "size": "18px", "lh": "28px", "use": "Lede, blurb" },
      "lg":  { "size": "22px", "lh": "30px", "use": "Section head" },
      "xl":  { "size": "32px", "lh": "38px", "use": "Page subhead" },
      "2xl": { "size": "56px", "lh": "60px", "use": "Hero / show name" }
    }
  },
  "space": {
    "0":  "0px",
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "24px",
    "6":  "32px",
    "7":  "48px",
    "8":  "64px",
    "9":  "96px",
    "10": "128px"
  },
  "radii": {
    "sm": "4px",
    "md": "8px",
    "lg": "16px"
  },
  "shadow": {
    "elev-1": "0 1px 0 rgba(0,0,0,0.25)",
    "elev-2": "0 1px 0 rgba(0,0,0,0.45)",
    "elev-3": "0 1px 0 rgba(0,0,0,0.65)",
    "_note": "Contract: single 1px offset only. Opacity varies, never the geometry."
  },
  "motion": {
    "duration": {
      "quick": "120ms",
      "base":  "240ms",
      "calm":  "480ms"
    },
    "ease": {
      "rise":   "cubic-bezier(.2,.8,.2,1)",
      "settle": "cubic-bezier(.4,0,.2,1)",
      "linear": "linear",
      "dwell":  "cubic-bezier(.6,0,.8,0)"
    },
    "reduced": "Replace all transforms with opacity fades at duration.base."
  }
}
