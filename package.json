{
  "name": "tiered",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm tokens && next build",
    "start": "next start -p 4173",
    "tokens": "node scripts/tokens-to-css.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:scripts": "node --test scripts/__tests__/*.test.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "e2e": "pnpm --dir apps/e2e exec playwright test",
    "e2e:install": "pnpm --dir apps/e2e install && pnpm --dir apps/e2e exec playwright install --with-deps chromium",
    "e2e:ui": "pnpm --dir apps/e2e exec playwright test --ui",
    "e2e:full": "E2E_FULL=1 pnpm --dir apps/e2e exec playwright test",
    "content:check": "tsx scripts/content-check.ts",
    "content:quota": "node scripts/content-quota.mjs",
    "check:no-raw-img": "node scripts/check-no-raw-img.mjs",
    "check:test-colocation": "node scripts/check-test-colocation.mjs",
    "size": "node scripts/size.mjs",
    "verify": "pnpm tokens && pnpm typecheck && pnpm check:no-raw-img && pnpm check:test-colocation && pnpm test:run && pnpm test:scripts && pnpm content:check && pnpm build && pnpm e2e",
    "deploy:check": "node scripts/deploy-check.mjs"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.20.0",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/analytics": "^2.0.0",
    "@vercel/speed-insights": "^1.0.0",
    "gray-matter": "^4.0.3",
    "next": "^15.4.0",
    "openai": "^6.37.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@panva/hkdf": "^1.2.0",
    "@resvg/resvg-js": "^2.6.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "jose": "^6.0.0",
    "jsdom": "^25.0.0",
    "png-to-ico": "^2.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
