{
  "name": "pantheon",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm tokens && next build",
    "start": "next start -p 4173",
    "tokens": "node scripts/tokens-to-css.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "e2e": "pnpm --dir apps/e2e exec playwright test",
    "e2e:install": "pnpm --dir apps/e2e install && pnpm --dir apps/e2e exec playwright install --with-deps chromium",
    "e2e:ui": "pnpm --dir apps/e2e exec playwright test --ui",
    "verify": "pnpm tokens && pnpm typecheck && pnpm test:run && pnpm build && pnpm e2e",
    "deploy:check": "node scripts/deploy-check.mjs"
  },
  "dependencies": {
    "next": "^15.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@vercel/analytics": "^2.0.0",
    "@vercel/speed-insights": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "vitest": "^3.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^25.0.0",
    "@biomejs/biome": "^2.0.0",
    "jose": "^6.0.0",
    "@panva/hkdf": "^1.2.0",
    "@resvg/resvg-js": "^2.6.0",
    "png-to-ico": "^2.1.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  }
}
